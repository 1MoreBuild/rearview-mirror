{
  "name": "rearview-mirror",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check:loc": "node --import tsx scripts/check-ts-max-loc.ts --max 500",
    "check:data": "node --import tsx scripts/check-data-integrity.ts",
    "check": "pnpm lint && pnpm test && pnpm check:loc && pnpm check:data"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
